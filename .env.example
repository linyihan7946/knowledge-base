# OpenAI-compatible API settings.
# DashScope example:
# KB_API_KEY=your_dashscope_api_key
# KB_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

KB_API_KEY=
KB_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Models
KB_LLM_MODEL=qwen-plus
KB_EMBEDDING_MODEL=text-embedding-v3

# Raw Markdown note folders, separated by semicolons.
# The default supports both the generic template path and the original personal paths.
WIKI_RAW_DIRS=raw/notes;raw/ai;raw/mubu
